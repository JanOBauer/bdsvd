?bdsvd::ispca
requireNamespace("plsgenomics", quietly = TRUE)
data("leukemia", package = "plsgenomics")
X <- scale(leukemia$X)
# Run IS-PCA
ispca.obj <- ispca(X = leukemia$X, anp = "1")
vhat <- ispca.obj$v[, 1:2]
ispc <- X %*% vhat
round(colSums(vhat != 0)/ncol(X), 2)
# Plot the first two principal components
plot(ispc, pch = leukemia$Y^2, xlab = "PC1", ylab = "PC2", main = "IS-PCA")
# Compare to CDM-PCA (see cdm.pca(...))
pca.obj <- cdm.pca(X = X, K = 2)
pc <- X %*% pca.obj$v
par(mfrow = c(1, 2))
plot(ispc, pch = leukemia$Y^2, xlab = "PC1", ylab = "PC2", main = "IS-PCA")
plot(pc, pch = leukemia$Y^2, xlab = "PC1", ylab = "PC2", main = "PCA")
par(mfrow = c(1, 1))
data("leukemia", package = "plsgenomics")
X <- scale(leukemia$X)
# Run IS-PCA
ispca.obj <- ispca(X = leukemia$X, anp = "4")
vhat <- ispca.obj$v[, 1:2]
ispc <- X %*% vhat
#' p <- 500 #Number of variables
#' n <- 500 #Number of observations
#' b <- 10  #Number of blocks
#' design <- "c" #Simulation design "a", "b", "c", or "d".
#'
#' #Simulate data matrix X
#' set.seed(1)
#' Sigma <- bdsvd.cov.sim(p = p, b = b, design = design)
#' X <- mvtnorm::rmvnorm(n, mean = rep(0, p), sigma = Sigma)
#' colnames(X) <- seq_len(p)
#'
#' bdsvd(X, standardize = FALSE)
pca.obj <- cdm.pca(X = X, K = 2)
pc <- X %*% pca.obj$v
par(mfrow = c(1, 2))
plot(ispc, pch = leukemia$Y^2, xlab = "PC1", ylab = "PC2", main = "IS-PCA")
plot(pc, pch = leukemia$Y^2, xlab = "PC1", ylab = "PC2", main = "PCA")
par(mfrow = c(1, 1))
p <- 500 #Number of variablesn <- 500 #Number of observations
n <- 100 #Number of variablesn <- 500 #Number of observations
b <- 10  #Number of blocks
design <- "c" #Simulation design "a", "b", "c", or "d".
#Simulate data matrix X
set.seed(1)
Sigma <- bdsvd.cov.sim(p = p, b = b, design = design)
X <- mvtnorm::rmvnorm(n, mean = rep(0, p), sigma = Sigma)
colnames(X) <- seq_len(p)
bdsvd(X, standardize = FALSE)
bdsvd(X, anp = "1", standardize = FALSE)
bdsvd(X, anp = "4", standardize = FALSE)
robust.bdsvd(X, anp = "1")
)
robust.bdsvd <- function(X,
B = 100,
dof.lim,
anp = "2",
standardize = TRUE,
scores = FALSE,
CV = TRUE,
k = 5,
max.iter
) {
ANP <- c("1", "2", "3", "4")
if (!(anp %in% ANP))
stop(sprintf("%s is an invalid option for anp.", anp))
if (missing(max.iter)) {
max.iter <- 500
}
p <- ncol(X)
n <- nrow(X)
X <- scale(X, center = TRUE, scale = standardize)
if (length(colnames(X)) == 0) {
colnames(X) <- as.character(seq_len(p))
}
if (length(unique(colnames(X))) != p) {
stop("Variable names are not unique.")
}
feature.names <- colnames(X)
if (!CV) {
Freq <- matrix(0, p, p)
for (i in 1:B) {
boot.obs <- sample(seq_len(n), n - 1, replace = FALSE)
X.boot <- X[boot.obs,  ]
bdsvd.boot <- bdsvd(X.boot, anp = anp, standardize = standardize, scores = scores, max.iter = max.iter)
print(paste0("here"))
for (i in 1:length(bdsvd.boot)) {
idx <- feature.names %in% bdsvd.boot[[i]]
Freq[idx, idx] <- Freq[idx, idx] + 1
}
}
return(Freq)
}
if (CV) {
if (missing(dof.lim)) {
dof.lim <- c(0, p - 1)
}
dof.lim <- sort(round(dof.lim))
if (dof.lim[1] < 0) {
dof.lim[1] <- 0
}
if (dof.lim[2] > p - 1) {
dof.lim[2] <- p - 1
}
dof.grid <- dof.lim[1]:dof.lim[2]
suppressWarnings(SVD <- irlba(X, nv = 1))
CV <- calc_CV(X, SVD$u, SVD$v, dof.grid, max.iter, as.integer(anp), k, n, p)
return(CV)
}
}
robust.bdsvd(X, anp = "1", CV = FALSE)
FREQ <- robust.bdsvd(X, anp = "1", CV = FALSE)
bdsvd::detect.blocks(FREQ/100, 0.9)
