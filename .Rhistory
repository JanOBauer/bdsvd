X <- scale(X)
obj1 <- bdsvd(X, anp = "3", scores = TRUE)
obj2 <- bdsvd(X, anp = "3", scores = FALSE)
BIC <- bdsvd.ht(X, anp = "3")$BIC
ht <- bdsvd.ht(X, anp ="3")
plot(0:(p-1), ht$BIC[,1], xlab = "|S|", ylab = "HBIC", main = "", type = "l")
single.bdsvd(X, dof = ht$dof, standardize = FALSE)
which.min(ht$BIC[,1])
cv <- robust.bdsvd(X, k = 10, anp = "3")
plot(0:(p-1), cv, xlab = "|S|", ylab = "MSE", main = "", type = "l")
which.min(cv)
